{
  "name": "fixly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next build",
    "start": "next start",
    "test": "npm run test:unit && npm run test:integration",
    "test:integration": "jest tests/integration --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:unit": "node ./node_modules/vitest/vitest.mjs run tests/unit --config vitest.config.ts --pool threads --maxWorkers 1 --no-file-parallelism",
    "test:unit:watch": "node ./node_modules/vitest/vitest.mjs tests/unit --config vitest.config.ts --pool threads --maxWorkers 1 --no-file-parallelism",
    "test:unit:coverage": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts --pool threads --maxWorkers 1 --no-file-parallelism --coverage",
    "test:all": "npm run test:unit && npm run test:integration",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit --incremental false",
    "verify:env": "node -r @swc-node/register lib/env.ts",
    "analyze": "cross-env ANALYZE=true npm run build",
    "build:analyze": "cross-env ANALYZE=true npm run build",
    "prepare": "husky install",
    "health": "curl http://localhost:3000/api/health || echo 'Server not running'",
    "db:reconcile-subscriptions": "npx ts-node --project tsconfig.json scripts/migrations/reconcile-subscriptions.ts"
  },
